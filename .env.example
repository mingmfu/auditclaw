# AuditClaw 环境变量配置
# 复制此文件为 .env 并填写真实值（.env 不会被提交到Git）

# 合信招标网登录账号
HX_USERNAME=your_username_here
HX_PASSWORD=your_password_here

# 可选：邮件通知配置
# EMAIL_SMTP_SERVER=smtp.example.com
# EMAIL_SMTP_PORT=587
# EMAIL_USERNAME=your_email@example.com
# EMAIL_PASSWORD=your_email_password
# EMAIL_RECIPIENTS=recipient@example.com
